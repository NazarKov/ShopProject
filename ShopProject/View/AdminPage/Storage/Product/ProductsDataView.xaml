<Page x:Class="ShopProject.View.AdminPage.Storage.Product.ProductsDataView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopProject.View.AdminPage.Storage.Product"
      xmlns:paginator="clr-namespace:ShopProject.View.TemplatePage" 
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:control="clr-namespace:ShopProject.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductsDataView">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/ButtonStyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/TextBoxStyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/TextBlockstyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/ComboBoxStyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/DataGridStyle.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <Grid x:Name="Grid"  Panel.ZIndex="0">
            <Grid.ContextMenu>
                <ContextMenu Name="context">
                    <MenuItem Header="Добавити товар" Command="{Binding OpenCreateProductWindowCommand}"/>
                    <MenuItem Header="Сфомувати товар" Command="{Binding OpenFormationProductWindowCommand}"></MenuItem>
                </ContextMenu>
            </Grid.ContextMenu>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>



            <i:Interaction.Triggers>
                <i:EventTrigger EventName="SizeChanged" SourceObject="{Binding ElementName=Grid}">
                    <i:InvokeCommandAction Command="{Binding UpdateSizeCommand}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Rectangle x:Name="ShadowRect" Visibility="{Binding ShadowVisibility}" Fill="Black" Panel.ZIndex="1" Opacity="0.5" Grid.Column="0" Grid.Row="0" Grid.RowSpan="4" Grid.ColumnSpan="3">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseDown">
                        <i:InvokeCommandAction Command="{Binding LostFocusCommand}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Rectangle>
            <Border BorderBrush="#BFBFBF" MinHeight="33" MinWidth="250" Margin="15,15,15,0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Background="#F2F2F2"
                    Panel.ZIndex="2"
                    BorderThickness="1" >
                <StackPanel  Orientation="Horizontal">
                    <Viewbox  VerticalAlignment="Top" Height="30" Width="35" Panel.ZIndex="1">
                        <Image Source="/Resource/Images/Search.png"/>
                    </Viewbox>
                    <control:TextBoxStretching    
                             Padding="0,3,0,0"
                             WidthTextBox="250"
                             HeightTextBox="30"
                             MinHeightTextBox="30"
                             MinWidthTextBox="250"
                             MaxHeightTextBox="400"
                             MaxWidthTextBox="600"
                             LostFocusHeightTextBox="30"
                             LostFocusWidthTextBox="250"
                             TextBlockVisibility="Collapsed"
                             Panel.ZIndex="1" 
                             x:Name="textboxSearch"  
                             Text="{Binding SearchItem}"
                             ExternalShadowVisibility="{Binding ShadowVisibility , Mode=TwoWay}"
                             ExternalLostFocusCommand="{Binding LostFocusCommand , Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#F2F2F2" 
                             BorderThickness="0" > 

                    </control:TextBoxStretching>
                </StackPanel>
            </Border>
            <Grid Grid.Row="0" Margin="10,10,0,10" VerticalAlignment="Top"  Panel.ZIndex="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" Panel.ZIndex="1" Margin="300,0,0,0">
                    <Button Grid.Column="0"
                            x:Name="button"
                            Style="{StaticResource GeneralButton}"
                            Margin="5"
                            Height="35"
                            Width="35" 
                            VerticalAlignment="Center"
                            Background="CadetBlue"
                            BorderBrush="#707070"
                            Command="{Binding UpdateProductDataGridView}">
                        <TextBlock Text="⟳"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <ComboBox x:Name="comboBox"
                                HorizontalAlignment="Right" 
                                Style="{StaticResource ModernComboBox}"
                                ItemContainerStyle="{StaticResource StorageComboBoxItem}"
                                ItemsSource="{Binding CountShowList}"
                                SelectedIndex="{Binding SelectIndexCountShowList}"
                                Height="35"
                                FontSize="20" 
                                VerticalContentAlignment="Center"
                                HorizontalContentAlignment="Left"
                                VerticalAlignment="Center" 
                                Width="100"
                                Margin="5"  >
                    </ComboBox>

                    <ComboBox x:Name="comboBoxTypeStatusProduct" 
                                Style="{StaticResource ModernComboBox}"
                                ItemContainerStyle="{StaticResource StorageComboBoxItem}"
                                ItemsSource="{Binding StatusProducts}"
                                SelectedIndex="{Binding SelectedStatusProduct}"
                                Height="35"
                                FontSize="20" 
                                VerticalContentAlignment="Center"
                                HorizontalContentAlignment="Left"
                                VerticalAlignment="Center" 
                                Width="320"
                                Margin="5"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right"  Orientation="Horizontal" Grid.Column="2" Panel.ZIndex="0" Margin="0,0,15,0">
                    <Button Grid.Column="3" Height="35" Content="Добавити товар" Style="{StaticResource StorageButton}" 
                            VerticalAlignment="Center" 
                            Padding="5"
                            HorizontalAlignment="Right"
                            Margin="5" Command="{Binding OpenCreateProductWindowCommand}"  />
                    <Button Grid.Column="4" Height="35" Content="Сформувати товар" Style="{StaticResource StorageButton}" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Padding="5"
                            Margin="5"
                            Command="{Binding OpenFormationProductWindowCommand}" />
                    <Button Grid.Column="5" Height="35" Content="Імпортувати товар"
                            Style="{StaticResource StorageButton}"  
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Padding="5"
                            Margin="5"
                            Command="{Binding OpenImportProductWhichExelCommand}" />
                    <Button Grid.Column="6" Height="35" Content="Експортувати товар"
                            Style="{StaticResource StorageButton}" VerticalAlignment="Center" 
                            HorizontalAlignment="Right"
                            Padding="5"
                            Margin="5,0,0,0"
                            Command="{Binding OpenExportProductToExelCommand}"/>


                </StackPanel>
            </Grid>

            <DataGrid Name="list"   
                      Margin="15,0,15,0"
                      Grid.Column="0" 
                      Grid.Row="1" 
                      ItemsSource="{Binding ProductList}"       
                      FontSize="16" 
                      RowHeight="40"  
                      Panel.ZIndex="0"
                      Style="{StaticResource DataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeader}" 
                      RowStyle="{StaticResource DataGridRow}"
                      CellStyle="{StaticResource RectangleCellStyle}" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Штрих код"  Binding="{Binding Code}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"> 
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0,20,0"></Setter>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Назва"  Binding="{Binding NameProduct}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,20,0"></Setter>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Артикул" Binding="{Binding Articule}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/> 
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Ціна"  Binding="{Binding Price}" Width="Auto" MinWidth="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Кількість" Binding="{Binding Count}" Width="Auto" MinWidth="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Одниці"  Binding="{Binding Unit.ShortNameUnit}" Width="Auto" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="КодУКТЗЕД" Binding="{Binding CodeUKTZED.Code}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Статус" Width="250">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Grid.Column="0"
                                        Grid.Row="0"
                                        Padding="8,3" 
                                        CornerRadius="2"
                                        HorizontalAlignment="Left" Margin="6">

                                    <StackPanel Orientation="Horizontal">

                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Margin="0,0,5,0"
                                                 Fill="White"/>

                                        <TextBlock Text="{Binding StatusString}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>

                                    </StackPanel>

                                    <Border.Style>

                                        <Style TargetType="Border">

                                            <Setter Property="Background" Value="Gray"/>

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding Status}" Value="Unknown">
                                                    <Setter Property="Background" Value="#F59E0B"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Status}" Value="DeservesAttention">
                                                    <Setter Property="Background" Value="#F59E0B"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Status}" Value="OutStock">
                                                    <Setter Property="Background" Value="#3B82F6"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Status}" Value="Archived">
                                                    <Setter Property="Background" Value="#6B7280"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Status}" Value="InStock">
                                                    <Setter Property="Background" Value="#10B981"/>
                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>

                                    </Border.Style>

                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Добавити товар" Command="{Binding OpenCreateProductWindowCommand}"/>
                        <MenuItem
                            Header="Редагувати товар"
                            CommandParameter="{Binding Path=PlacementTarget.SelectedItems,RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                            Command="{Binding UpdateProductCommand}" />
                        <Separator></Separator>
                        <MenuItem Header="Перенести в архів"
                            CommandParameter="{Binding Path=PlacementTarget.SelectedItems,RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                            Command="{Binding AddProductArhiveCommand}" />
                        <MenuItem Header="Товар закінчився"
                            CommandParameter="{Binding Path=PlacementTarget.SelectedItems,RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                            Command="{Binding AddOutOfStockProductCommand}" />
                        <MenuItem Header="Роздрукувати етикетку"
                            CommandParameter="{Binding Path=PlacementTarget.SelectedItems,RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                            Command="{Binding OpenWindoiwCreateStikerCommand}" />
                        <Separator></Separator>
                        <MenuItem Header="Поставка товару" Command="{Binding OpenDeliveriOfProductCommand}"></MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <TextBlock Text="Нічого не знайдено"
               Grid.Column="0" Grid.Row="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="18"
               Opacity="0.5">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ProductList.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <paginator:Paginator x:Name="BottomButtomPaginator1" Grid.Row="2" DataContext="{Binding Paginator}" Margin="10"  HorizontalAlignment="Center" VerticalAlignment="Center"></paginator:Paginator>

            <StatusBar Grid.Row="3" Height="50" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Background="White">
                <StatusBarItem>
                    <Label Content="{Binding StatusBarCountProduct}"></Label>
                </StatusBarItem>
            </StatusBar>

        </Grid>
    </Grid>
</Page>
