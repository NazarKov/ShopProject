<Page x:Class="ShopProject.View.Integration.Windows.Service.RegisterWindowsServiceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopProject.View.Integration.Windows.Service"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterWindowsService">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/ButtonStyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/TextBlockstyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
 
        <Border Grid.Row="0" 
                VerticalAlignment="Top"
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Border Grid.Column="0"
                        Grid.Row="0"
                        Padding="8,3" 
                        CornerRadius="2"
                        HorizontalAlignment="Left" Margin="6">

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Статус: "
                                   FontWeight="Bold"/>
                        <Ellipse Width="8"
                                 Height="8"
                                 Margin="0,0,5,0"
                                 Fill="White"/>

                        <TextBlock Text="{Binding StatusService}"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                    <Border.Style>

                        <Style TargetType="Border">

                            <Setter Property="Background" Value="Gray"/>

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding StatusService}" Value="StartPending">
                                    <Setter Property="Background" Value="#F59E0B"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding StatusService}" Value="StopPending">
                                    <Setter Property="Background" Value="#F59E0B"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding StatusService}" Value="Running">
                                    <Setter Property="Background" Value="ForestGreen"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding StatusService}" Value="ContinuePending">
                                    <Setter Property="Background" Value="ForestGreen"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding StatusService}" Value="PausePending">
                                    <Setter Property="Background" Value="#F59E0B"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusService}" Value="Paused">
                                    <Setter Property="Background" Value="#F59E0B"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusService}" Value="NotCreate">
                                    <Setter Property="Background" Value="Red"/>
                                </DataTrigger>
                            </Style.Triggers>

                        </Style> 
                    </Border.Style> 
                </Border> 
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Grid.Row="1"
                Visibility="{Binding MessegeBlockVisibiliti}"
                Background="#FFFFFF"
                Width="350"
                CornerRadius="2" 
                BorderBrush="#D0D0D0" Padding="10"
                Margin="0,0,0,10"
                BorderThickness="1" >
            <StackPanel>
                <TextBlock x:Name="textBlock"
                    Visibility="{Binding ErrorTextBlockVisibiliti}"
                    Style="{StaticResource ErrorTextBlock}"
                    Grid.RowSpan="2" 
                    Text="{Binding Error}"  
                    Height="35" 
                    Padding="8" />
                <TextBlock x:Name="textBlock1" 
                    Visibility="{Binding SuccessTextBlockVisibiliti}"
                    Style="{StaticResource SuccessTextBlock}"
                    Grid.RowSpan="2" 
                    Text="{Binding Success}"  
                    Height="35"
                    Padding="8" />
            </StackPanel>
        </Border>

        <Border Padding="25"
                Grid.Row="2"
                Width="350"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                CornerRadius="2"
                Background="#FFFFFF"
                BorderBrush="#DDDDDD" 
                BorderThickness="1" >
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="Створення сервісу бази даних" Background="Transparent" FontSize="20" HorizontalAlignment="Center" Style="{StaticResource GeneralTextBlock}"/>
                <Button Content="Створити сервіс"
                        Height="35" 
                        Margin="10"
                        Command="{Binding CreateWindowsService}"
                        Style="{StaticResource GeneralButton}" />

                <Button Content="Запустити сервіс"
                        Height="35"
                        Margin="10,0,10,0"
                        Command="{Binding StartWindowsService}"
                        Style="{StaticResource SuccessButton}" />
                <Button Content="Підключитися до сервісу"
                        Height="35"
                        Margin="10"
                        Command="{Binding RedirectToConnectServicePage}"
                        Style="{StaticResource SuccessButton}" />

                <Button Content="Зупинити сервіс"
                        Height="35"
                        Margin="10,0,10,0"
                        Command="{Binding StopWinodwsService}"
                        Style="{StaticResource ExitButton}" />
                <Button Content="Видалити сервіс"
                        Height="35"
                        Margin="10"
                        Command="{Binding DeleteWindowsService}"
                        Style="{StaticResource ExitButton}" />
                <Button Content="Повернутися назад"
                        Height="35"
                        Margin="10,0,10,0"
                        Command="{Binding RedirectToStartPage}"
                        Style="{StaticResource GeneralButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
