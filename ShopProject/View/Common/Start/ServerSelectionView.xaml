<Page x:Class="ShopProject.View.Common.Start.ServerSelectionView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopProject.View.Common.Start"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ServerSelectionView">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/ButtonStyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/TextBoxStyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/TextBlockStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid Background="#F3F3F3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="440"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="{Binding HeightGrid}"/>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Column="1" Grid.Row="1"
                Visibility="{Binding MessegeBlockVisibiliti}"
                Background="#FFFFFF"
                CornerRadius="2" 
                BorderBrush="#D0D0D0" Padding="10"
                Margin="0,0,0,10"
                BorderThickness="1" >
            <StackPanel>
                <TextBlock x:Name="textBlock"
                           Visibility="{Binding ErrorTextBlockVisibiliti}"
                           Style="{StaticResource ErrorTextBlock}"
                           Grid.RowSpan="2" 
                           Text="{Binding Error}"  
                           Height="35" 
                           Padding="8" />
                <TextBlock x:Name="textBlock1" 
                           Visibility="{Binding SuccessTextBlockVisibiliti}"
                           Style="{StaticResource SuccessTextBlock}"
                           Grid.RowSpan="2" 
                           Text="{Binding Success}"  
                           Height="35"
                           Padding="8" />
            </StackPanel>
        </Border>
        <Border Grid.Column="1" Grid.Row="2"
                Background="#FFFFFF"
                CornerRadius="2"
                Padding="20"
                BorderBrush="#D0D0D0"
                BorderThickness="1" >

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Налаштування підключення"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#2E2E2E"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

                <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <Label Content="Назва бази даних:"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                        <TextBox Width="180" Height="30" VerticalContentAlignment="Center" Text="{Binding NameServer}" Style="{StaticResource GeneralTextBox}"    />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Label Content="URL бази даних:"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"
                           Margin="0,0,22,0"/>
                    <TextBox Width="180" Height="30" VerticalContentAlignment="Center" Text="{Binding Url}" Style="{StaticResource GeneralTextBox}"    />
                    <Button Content="Авто пошук"
                            Command="{Binding ShowSettingAutoFindCommand}"
                            Style="{StaticResource GeneralButton}"
                            Margin="10,0,0,0"
                            Width="80"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2"
                    Visibility="{Binding VisibilitySettingAutoFind}"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center">

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Label Content="IP Router:" Foreground="#4A4A4A" Width="100"/>
                        <TextBox Width="160" Text="{Binding IpRouter}" Background="#F7F7F7" Foreground="#2E2E2E"
                         BorderBrush="#C0C0C0" BorderThickness="1" Padding="5" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Label Content="Port:" Foreground="#4A4A4A" Width="100"/>
                        <TextBox Width="160" Text="{Binding Port}" Background="#F7F7F7" Foreground="#2E2E2E"
                         BorderBrush="#C0C0C0" BorderThickness="1" Padding="5"  />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Label Content="Min IP:" Foreground="#4A4A4A" Width="100"/>
                        <TextBox Width="160" Text="{Binding MinIPAddress}" Background="#F7F7F7" Foreground="#2E2E2E"
                         BorderBrush="#C0C0C0" BorderThickness="1" Padding="5"  />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Label Content="Max IP:" Foreground="#4A4A4A" Width="100"/>
                        <TextBox Width="160" Text="{Binding MaxIPadress}" Background="#F7F7F7" Foreground="#2E2E2E"
                         BorderBrush="#C0C0C0" BorderThickness="1" Padding="5"  />
                    </StackPanel>

                    <Button Content="Пошук"
                            Command="{Binding AutoFindUrlCommand}" 
                            Style="{StaticResource GeneralButton}"
                            Height="30"
                            Margin="0,10,0,0"
                            Width="120"
                            HorizontalAlignment="Center"/> 
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="Підключитися"  
                            Command="{Binding ConnectCommand}" 
                            Style="{StaticResource SuccessButton}" 
                            Height="30"
                            Width="120"
                            Margin="0,0,10,0"/>
                    <Button Content="Назад" 
                            Height="30"
                            Command="{Binding RediredtStartCommand}"
                            Style="{StaticResource ExitButton}"
                            Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Margin="0,15,0,0" Grid.Column="1" Grid.Row="3" Visibility="{Binding  VisibilityOldUrl}"
                Background="#FFFFFF"
                CornerRadius="2"
                Padding="20"
                BorderBrush="#D0D0D0"
                BorderThickness="1" >
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Старі підключення"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#2E2E2E"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding OldUrls}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                CommandParameter="{Binding}"
                                Command="{Binding DataContext.ConnectOldUrlCommand , RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                Style="{StaticResource GeneralButton}"
                                Content="{Binding}"
                                Height="30"
                                Margin="0,10,0,0"
                                Width="200"
                                HorizontalAlignment="Center"></Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</Page>
