<Page x:Class="ShopProject.View.Common.ConnectionLost.ConnectionLostView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopProject.View.Common.ConnectionLost"
      xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConnectionLostView">

    <Grid>
        <!-- Напівпрозорий фон -->
        <Grid Background="#AA000000"/>

        <!-- Центральна картка -->
        <Border Width="320"
            Padding="20"
            Background="#1E1E1E"
            CornerRadius="15"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel HorizontalAlignment="Center">

                <!-- Заголовок -->
                <TextBlock Text="Втрата підключення"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

                <!-- Підзаголовок -->
                <TextBlock Text="Спроба перепідключення..."
                       Foreground="#AAAAAA"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

                <!-- Loader -->
                <Border Background="#2A2A2A"
                    CornerRadius="10"
                    Padding="10">
                    <Image Width="100"
                       Height="100"
                       HorizontalAlignment="Center"
                       gif:AnimationBehavior.SourceUri="..\..\..\Resource\gif\Loading.gif"/>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</Page>
