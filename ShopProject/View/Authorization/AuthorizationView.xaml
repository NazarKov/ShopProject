<Page x:Class="ShopProject.View.Authorization.AuthorizationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopProject.View.Authorization"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="AuthorizationView">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/ButtonStyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/TextBoxStyle.xaml"/>
                <ResourceDictionary Source="/Resource/Theme/LightTheme/TextBlockStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="400"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="400"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1"
                Grid.Column="1"
                Visibility="{Binding MessegeBlockVisibiliti}"
                Background="#FFFFFF"
                CornerRadius="2" 
                BorderBrush="#D0D0D0" Padding="10"
                Margin="0,0,0,10"
                BorderThickness="1" >
            <StackPanel>
                <TextBlock x:Name="textBlock"
                    Visibility="{Binding ErrorTextBlockVisibiliti}"
                    Style="{StaticResource ErrorTextBlock}"
                    Grid.RowSpan="2" 
                    Text="{Binding Error}"  
                    Height="35" 
                    Padding="8" />
                <TextBlock x:Name="textBlock1" 
                    Visibility="{Binding SuccessTextBlockVisibiliti}"
                    Style="{StaticResource SuccessTextBlock}"
                    Grid.RowSpan="2" 
                    Text="{Binding Success}"  
                    Height="35"
                    Padding="8" />
            </StackPanel>
        </Border>

        <Border Background="#FFFFFF"
                Grid.Row="2"
                Grid.Column="1"
                CornerRadius="2"
                Padding="40"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch" 
                BorderBrush="#D0D0D0"
                BorderThickness="1" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Вхід у систему"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#2E2E2E"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <Label Content="Логін"
                       FontSize="16"
                       Foreground="#4A4A4A"
                       Grid.Row="1"
                       HorizontalAlignment="Left"
                       Margin="20,0,0,3"/>
                <TextBox Text="{Binding Login}"
                         Style="{StaticResource GeneralTextBox}"
                         VerticalContentAlignment="Center"
                         Grid.Row="2"  
                         HorizontalAlignment="Stretch" />

                <Label Content="Пароль"
                       FontSize="16"
                       Foreground="#4A4A4A"
                       Grid.Row="3"
                       HorizontalAlignment="Left"
                       Margin="20,15,0,3"/>
                <TextBox x:Name="PasswordBox"  
                         VerticalContentAlignment="Center"
                         Style="{StaticResource GeneralTextBox}"
                         Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="4" 
                         Height="35"
                         HorizontalAlignment="Stretch" />

                <Button Content="Змінити пароль"
                        Command="{Binding OpenChangePasswordCommand}"
                        Grid.Row="4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,5,0"
                        Width="140"
                        Background="Transparent"
                        Foreground="#2563EB"
                        BorderThickness="0"
                        FontSize="13"
                        Cursor="Hand"/>

                <CheckBox Content="Автоматичний вхід"
                          IsChecked="{Binding AutoLogin}"
                          Grid.Row="5"
                          Margin="0,20,0,0"
                          Foreground="#4A4A4A"
                          FontSize="14"
                          HorizontalAlignment="Center"/>

                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                    <Button Content="Вхід"
                            Command="{Binding LogInCommnad}"
                            Style="{StaticResource SuccessButton}"
                            Width="150" 
                            Height="35"
                            Margin="5"
                            />
                    <Button Content="Вихід"
                            Command="{Binding ExitCommand}"
                            Style="{StaticResource ExitButton}"
                            Width="150" Margin="5"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
