@{
    Layout = ViewData["Layout"]?.ToString() ?? "_Layout";
    ViewData["Title"] = "ChangePassowrd Page";
}
@model ShopProjectWebServer.Models.UI.ProfileModel
<div>
    <div class="border admin-informaion">
        <div class="border admin-informaion-header">
            <p>Change User Password </p>
        </div>
        <div class="admin-informaion-header">
            <p class="error">@Model.Error</p>
        </div>
        <form asp-controller="Profile" asp-action="ChangeUserPassword" method="POST">
            <table class="table"> 
                <tr>
                    <th>Old Password</th>
                    <th>
                        <input asp-for="OldPassword" type="password" class="form-control" placeholder="write old password" />
                    </th>
                </tr>
                <tr>
                    <th>New Password</th>
                    <th>
                        <input asp-for="Password" type="password" class="form-control" placeholder="write password" />
                    </th>
                </tr>
            </table>
            <br />
            <div class="d-flex justify-content-end gap-2 mt-4">
                <button class="btn button button-size" >Змінити пароль</button>
            </div>
        </form>
        <div class="d-flex justify-content-end gap-2 mt-4">
            @using (Html.BeginForm("index", "Profile", FormMethod.Post))
            {
                <button class="btn button button-size">Повернутися назад</button>
            }
        </div>
    </div>
</div>
